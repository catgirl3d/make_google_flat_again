{
  "manifest_version": 3,
  "name": "Make Google Flat Again",
  "version": "0.1.0",
  "description": "Firefox-first extension for restoring classic Google Workspace icons with local assets and clean shared configuration.",
  "icons": {
    "16": "assets/extension/icon-16.png",
    "32": "assets/extension/icon-32.png",
    "48": "assets/extension/icon-48.png",
    "128": "assets/extension/icon-128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "https://www.gstatic.com/*"
  ],
  "action": {
    "default_title": "Make Google Flat Again",
    "default_icon": {
      "16": "assets/extension/icon-16.png",
      "32": "assets/extension/icon-32.png",
      "48": "assets/extension/icon-48.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "make-google-flat-again@alina.local",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "src/shared/runtime.js",
      "src/shared/apps.js",
      "src/shared/settings.js",
      "src/background/productlogo-dnr.js",
      "src/background/background.js"
    ],
    "service_worker": "src/background/background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "dnr-placeholder",
        "enabled": true,
        "path": "src/background/dnr-placeholder.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://drive.google.com/*"
      ],
      "css": [
        "src/content/styles/header-drive.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://docs.google.com/document/*"
      ],
      "css": [
        "src/content/styles/header-docs.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://docs.google.com/spreadsheets/*"
      ],
      "css": [
        "src/content/styles/header-sheets.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://docs.google.com/presentation/*"
      ],
      "css": [
        "src/content/styles/header-slides.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://docs.google.com/forms/*"
      ],
      "css": [
        "src/content/styles/header-forms.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chat.google.com/*",
        "https://keep.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://maps.google.com/*",
        "https://meet.google.com/*",
        "https://www.google.com/maps*",
        "https://www.google.com/maps/*"
      ],
      "js": [
        "src/shared/runtime.js",
        "src/shared/apps.js",
        "src/shared/guards.js",
        "src/shared/settings.js",
        "src/shared/targets.js",
        "src/content/debug-logger.js",
        "src/content/surface-registry.js",
        "src/content/surfaces/favicon.js",
        "src/content/surfaces/sidepanel.js",
        "src/content/main.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/apps/*",
        "assets/icons/calendar/*"
      ],
      "matches": [
        "https://chat.google.com/*",
        "https://keep.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://maps.google.com/*",
        "https://meet.google.com/*",
        "https://ogs.google.com/*",
        "https://www.gstatic.com/*",
        "https://www.google.com/maps*",
        "https://www.google.com/maps/*"
      ]
    }
  ]
}
